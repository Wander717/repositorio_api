<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sigap.controller.MainShellController"
            prefWidth="1366" prefHeight="768">

    <!-- TOPO: Seletor de Contexto Global + Banner Read-Only -->
    <top>
        <VBox>
            <ToolBar style="-fx-background-color: #2c3e50; -fx-padding: 6 12;">

                <Label text="Ano:" style="-fx-text-fill: #ecf0f1;"/>
                <ComboBox fx:id="cbAno" prefWidth="80" onAction="#handleContextChange"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Semestre:" style="-fx-text-fill: #ecf0f1;"/>
                <!-- ToggleGroup controlado pelo controller para garantir exclusividade -->
                <ToggleButton fx:id="tbSem1" text="1º" onAction="#handleSemestreToggle"/>
                <ToggleButton fx:id="tbSem2" text="2º" onAction="#handleSemestreToggle"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Curso:" style="-fx-text-fill: #ecf0f1;"/>
                <ComboBox fx:id="cbCurso" prefWidth="200" onAction="#handleContextChange"/>

                <Separator orientation="VERTICAL"/>

                <Label text="Sem. do Curso:" style="-fx-text-fill: #ecf0f1;"/>
                <ComboBox fx:id="cbSemestreCurso" prefWidth="80" onAction="#handleContextChange"/>

                <!-- Espaço flexível empurra info do usuário para a direita -->
                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="lblNomeUsuario" style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold;"/>
                <Label fx:id="lblPerfilUsuario" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
                <Separator orientation="VERTICAL"/>
                <Button text="Sair" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-border-color: #7f8c8d; -fx-border-radius: 3;"/>
            </ToolBar>

            <!-- Banner de modo somente leitura — visível apenas em períodos passados -->
            <Label fx:id="bannerReadOnly"
                   text="⚠   Você está visualizando um período passado — modo somente leitura"
                   maxWidth="Infinity" textAlignment="CENTER"
                   visible="false" managed="false"
                   style="-fx-background-color: #f39c12; -fx-text-fill: #2c3e50;
                          -fx-padding: 5 12; -fx-font-weight: bold; -fx-font-size: 12px;"/>
        </VBox>
    </top>

    <!-- ESQUERDA: Menu de navegação lateral (itens filtrados por perfil no controller) -->
    <left>
        <VBox fx:id="menuLateral" spacing="2"
              style="-fx-background-color: #34495e;" prefWidth="210">
            <padding><Insets top="14" right="8" bottom="14" left="8"/></padding>

            <!-- Seção ADM -->
            <VBox fx:id="secaoAdm" spacing="2" managed="false" visible="false">
                <Label text="ADMINISTRADOR"
                       style="-fx-text-fill: #95a5a6; -fx-font-size: 10px; -fx-padding: 6 0 2 4;"/>
                <Button text="📅  Calendário Acadêmico"
                        onAction="#navCalendario" maxWidth="Infinity" styleClass="menu-item"/>
                <Button text="🏫  Cursos e Horários"
                        onAction="#navCursosHorarios" maxWidth="Infinity" styleClass="menu-item"/>
                <Button text="👥  Coordenadores / ADMs"
                        onAction="#navCoordenaodresAdms" maxWidth="Infinity" styleClass="menu-item"/>
                <Button text="🚫  Bloqueios e Cancelamentos"
                        onAction="#navCalendario" maxWidth="Infinity" styleClass="menu-item"/>
            </VBox>

            <!-- Seção Coordenador -->
            <VBox fx:id="secaoCoordenador" spacing="2" managed="false" visible="false">
                <Label text="COORDENADOR"
                       style="-fx-text-fill: #95a5a6; -fx-font-size: 10px; -fx-padding: 6 0 2 4;"/>
                <Button text="📚  Disciplinas e Professores"
                        onAction="#navCoordPainel" maxWidth="Infinity" styleClass="menu-item"/>
            </VBox>

            <!-- Seção Professor -->
            <VBox fx:id="secaoProfessor" spacing="2" managed="false" visible="false">
                <Label text="PROFESSOR"
                       style="-fx-text-fill: #95a5a6; -fx-font-size: 10px; -fx-padding: 6 0 2 4;"/>
                <Button text="📝  Temas"
                        onAction="#navTemas" maxWidth="Infinity" styleClass="menu-item"/>
                <Button text="📋  Planejamento e Estatísticas"
                        onAction="#navPlanejamento" maxWidth="Infinity" styleClass="menu-item"/>
            </VBox>

        </VBox>
    </left>

    <!-- CENTRO: Área de conteúdo — FXMLs são carregados aqui via FXMLLoader -->
    <center>
        <StackPane fx:id="areaConteudo" style="-fx-background-color: #ecf0f1;">
            <Label text="Selecione uma seção no menu lateral."
                   style="-fx-text-fill: #95a5a6; -fx-font-size: 14px;"/>
        </StackPane>
    </center>

</BorderPane>